<!DOCTYPE html>
<html>
<head>
	<title>My Company</title>
	<style>
		body {
			font-family: Arial, sans-serif;
			margin: 0;
			padding: 0;
			background-image: url('https://via.placeholder.com/1500x1000'); /* Replace with your own image URL */
			background-size: cover;
			background-position: center;
			background-repeat: no-repeat;
			background-color: rgba(255, 255, 255, 0.8); /* Replace with your own color and opacity values */
		}
		nav {
			background-color: #333;
			color: #fff;
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 20px;
		}
		nav a {
			color: #fff;
			text-decoration: none;
			margin-right: 20px;
		}
		h1, h2 {
			text-align: center;
			margin-top: 50px;
		}
		section {
			margin: 50px auto;
			max-width: 800px;
			padding: 0 20px;
		}
		img {
			max-width: 100%;
			height: auto;
		}
		ul {
			list-style: none;
			padding: 0;
			margin: 0;
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
		}
		li {
			margin: 10px;
		}
		.contact-section {
			background-color: #f2f2f2;
			padding: 50px;
			display: flex;
			justify-content: center;
			align-items: center;
		}
		.contact-info {
			margin-right: 50px;
		}
		.contact-info h2 {
			margin-bottom: 20px;
		}
		.contact-info p {
			margin-bottom: 10px;
		}
	</style>
</head>
<body>
	<nav>
		<a href="#">My Company</a>
		<a href="#about">About</a>
		<a href="#delivery">Delivery</a>
		<a href="#contact">Contact</a>
	</nav>
